# MiroFish FinSight 环境变量示例
# 用法:复制本文件为 .env,并填入你自己的 API Key
#   copy .env_example .env   (Windows)   /   cp .env_example .env   (macOS/Linux)
# 注意:.env 已在 .gitignore 中,请勿提交真实密钥。
# 带 # (默认) 的项可不填,代码内置了默认值。

# ============ SiliconFlow(国产 Qwen,Agent 大脑)============
# 必填:在 https://siliconflow.cn/ 申请
SILICONFLOW_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# (默认) ReAct 编排"大脑",用强模型保证工具调用 + JSON 输出稳定
SILICONFLOW_AGENT_MODEL=Qwen/Qwen2.5-72B-Instruct
# (默认) 多智能体分析节点用的模型(全栈统一 72B,JSON 输出稳定)
SILICONFLOW_LLM_MODEL=Qwen/Qwen2.5-72B-Instruct
# (默认) 分析节点用的 Embedding(多语言,避免 bge-large-en-v1.5 在 SiliconFlow 上的 400)
SILICONFLOW_EMBED_MODEL=BAAI/bge-m3
# (默认) RAG 知识库用的多语言 Embedding(中英文均可检索)
SILICONFLOW_RAG_EMBED_MODEL=BAAI/bge-m3
# (默认) API 地址
SILICONFLOW_BASE_URL=https://api.siliconflow.cn/v1

# ============ Firecrawl(联网检索,可选)============
# 用于 web_search 工具与深度分析流水线的数据抓取;不填则只走本地知识库
# 申请地址:https://www.firecrawl.dev/
FIRECRAWL_API_KEY=fc-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ============ 其它(可选,均有默认值)============
# 图表/索引输出目录
# OUTPUT_DIR=./output
# 短期记忆保留的最近消息条数
# MEMORY_LAST_N=10
